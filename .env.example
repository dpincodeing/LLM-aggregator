# ─────────────────────────────────────────────────────────
#  LLM Aggregator — Environment Variables
#  Copy this file:  cp .env.example .env
# ─────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string
# Free options: https://railway.app  |  https://supabase.com
DATABASE_URL="postgresql://postgres:password@localhost:5432/llm_aggregator"

# ── Encryption ────────────────────────────────────────────
# AES-256-GCM key for encrypting stored API keys — NEVER commit the real value
# Generate one: openssl rand -hex 32
ENCRYPTION_KEY="replace_with_64_char_hex_from_openssl_rand_hex_32"

# ── LLM Provider API Keys ─────────────────────────────────
# Add the keys for providers you want to use.
# At least one is required to run the chat server.

GROQ_API_KEY="gsk_..."
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."

# ── Server ────────────────────────────────────────────────
PORT=3000
